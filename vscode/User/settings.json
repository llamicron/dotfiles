{
    // Font
    "editor.fontFamily": "Fira code",
    "editor.fontSize": 14,
    "editor.lineHeight": 35,
    // Theme and Appearance
    "workbench.colorTheme": "DuoTone Dark Sea",
    "window.zoomLevel": 0,
    "editor.roundedSelection": true,
    "editor.cursorBlinking": "expand",
    "workbench.fontAliasing": "antialiased",
    "editor.lineNumbers": "on",
    "editor.wordWrap": "off",
    "editor.fontLigatures": true,
    "editor.renderIndentGuides": true,
    "editor.renderLineHighlight": "line",
    "editor.codeLens": true,
    "editor.selectionHighlight": false,
    "editor.minimap.enabled": false,
    // Files
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/.vscode": true,
        "**/*.pyc": true,
        ".cache": true,
        "**/__pycache__": true,
        "Cargo.lock": true,
        ".ropeproject": true
    },
    // Behavior
    "editor.formatOnPaste": true,
    "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?",
    "editor.tabCompletion": true,
    // Terminal
    "terminal.external.osxExec": "Iterm2",
    "terminal.integrated.shell.osx": "/bin/zsh",
    // "terminal.integrated.fontLigatures": true,
    "terminal.integrated.fontSize": 16,
    "terminal.integrated.lineHeight": 1.6,
    "terminal.integrated.cursorStyle": "line",
    // Tabs
    "editor.tabSize": 2,
    "editor.detectIndentation": true,
    // Status Bar Color (purple all the time)
    "workbench.colorCustomizations": {
        // Purple
        // "statusBar.background": "#68217A",
        // Green
        "statusBar.background": "#00aa66e0",
        "statusBar.noFolderBackground": "#EFF1F3",
        "statusBar.debuggingBackground": "#68217A"
    },
    // Workbench
    "workbench.tips.enabled": false,
    "workbench.editor.enablePreview": false,
    // File Explorer
    "explorer.openEditors.visible": 0,
    "explorer.sortOrder": "type",
    // Search
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/.shards": true,
        "*.db": true,
        "**/*cache": true,
        "**/*__pycache__": true
    },
    // Getting around Microsoft's bullshit
    "telemetry.enableTelemetry": false,
    "telemetry.enableCrashReporter": false,
    // Language overrides
    "[python]": {
        "editor.tabSize": 4
    },
    "[html]": {
        "editor.lineHeight": 43
    },
    // Git
    "git.path": "/usr/bin/git",
    // "workbench.welcome.enabled": false,
    "workbench.statusBar.visible": true,
    // Extensions
    // Journal
    "git.enableSmartCommit": true,
    "atomKeymap.promptV3Features": true,
    "editor.multiCursorModifier": "ctrlCmd",
    // Python
    "python.linting.enabled": false,
    // Misc
    "workbench.startupEditor": "none",
    "vsicons.dontShowNewVersionMessage": true,
    "explorer.confirmDragAndDrop": false,
    "extensions.ignoreRecommendations": false,
    "workbench.activityBar.visible": true,
    "editor.snippetSuggestions": "top",
    "git.confirmSync": false,
    "licenseheader.Author": "llamicron",
    "licenseheader.CopiedBy": "Copyright (c) 2018 llamicron",

    // Macros
    "macros": {
        "CommentDown": [
            "editor.action.copyLinesDownAction",
            "cursorUp",
            "editor.action.addCommentLine",
            "cursorDown"
        ]
    },
    "python.linting.lintOnSave": true,
    "vsnotes.defaultNotePath": "/Users/llamicron/code/notes/",
    "vsnotes.defaultNoteTitle": "{title}.{ext}",
    "workbench.iconTheme": "vscode-icons",
    "rust.rustup": {
        "toolchain": "stable-x86_64-apple-darwin",
        "nightlyToolchain": "nightly-x86_64-apple-darwin"
    },
    "rust.mode": "rls",

    "[rust]": {
        "editor.tabSize": 4
    },
    "workbench.statusBar.feedback.visible": false,
    "files.autoSave": "off",
}

{
"Python Gitignore": {
	"prefix": "python-gitignore",
	"description": "A standard .gitignore for Python Projects",
	"body": [
		"# Byte-compiled / optimized / DLL files",
		"__pycache__/",
		"*.py[cod]",
		"*py.class",
		"# C extensions",
		"*.so",
		"\n",
		"# Distribution / packaging",
		".Python",
		"build/",
		"develop-eggs/",
		"dist/",
		"downloads/",
		"eggs/",
		".eggs/",
		"lib/",
		"lib64/",
		"parts/",
		"sdist/",
		"var/",
		"wheels/",
		"*.egg-info/",
		".installed.cfg",
		"*.egg",
		"MANIFEST",
		"\n",
		"# PyInstaller",
		"#  Usually these files are written by a python script from a template",
		"#  before PyInstaller builds the exe, so as to inject date/other infos into it.",
		"*.manifest",
		"*.spec",
		"\n",
		"# Installer logs",
		"pip-log.txt",
		"pip-delete-this-directory.txt",
		"\n",
		"# Unit test / coverage reports",
		"htmlcov/",
		".tox/",
		".coverage",
		".coverage.*",
		".cache",
		"nosetests.xml",
		"coverage.xml",
		"*.cover",
		".hypothesis/",
		"\n",
		"# Translations",
		"*.mo",
		"*.pot",
		"\n",
		"# Django stuff:",
		"*.log",
		".static_storage/",
		".media/",
		"local_settings.py",
		"\n",
		"# Flask stuff:",
		"instance/",
		".webassets-cache",
		"\n",
		"# Scrapy stuff:",
		".scrapy",
		"\n",
		"# Sphinx documentation",
		"docs/_build/",
		"\n",
		"# PyBuilder",
		"target/",
		"\n",
		"# Jupyter Notebook",
		".ipynb_checkpoints",
		"\n",
		"# pyenv",
		".python-version",
		"\n",
		"# celery beat schedule file",
		"celerybeat-schedule",
		"\n",
		"# SageMath parsed files",
		"*.sage.py",
		"\n",
		"# Environments",
		".env",
		".venv",
		"env/",
		"venv/",
		"ENV/",
		"env.bak/",
		"venv.bak/",
		"\n",
		"# Spyder project settings",
		".spyderproject",
		".spyproject",
		"\n",
		"# Rope project settings",
		".ropeproject",
		"\n",
		"# mkdocs documentation",
		"/site",
		"\n",
		"# mypy",
		".mypy_cache/"
	]
}
}
